# Alternative to main.tf — uses Route53 for api.your-task.dev instead of Azure DNS directly.
#
# HOW TO USE:
#   1. Delete (or rename) main.tf
#   2. Rename this file to main.tf
#   3. Run: terraform init && terraform apply
#   4. After apply, copy the 4 NS values from output "route53_name_servers"
#   5. Add a NS record in Azure DNS:
#        Zone: your-task.dev  |  Name: api  |  Type: NS  |  Values: <the 4 NS values>
#
# WHY THIS APPROACH:
#   - No azurerm provider needed — everything stays in AWS
#   - ACM validation is handled natively via aws_route53_record
#   - API Gateway gets a proper ALIAS record (not a CNAME) for better DNS behaviour
#   - Azure DNS only needs one manual NS delegation record, set once and never touched again

locals {

  ecr = {
    "aws-lambda-with-spring" = {
      source_image     = "ghcr.io/samitkumarpatel/aws-lambda-with-spring:latest"
      source_image_tag = "latest"
    }
  }

  s3 = []

  functions = {
    "aws-lambda-with-spring" = {
      memory_size           = 3008
      environment_variables = {}
      enable_function_url   = false
      api_gateway_route = {
        path_prefix   = "api"
        path_rewrites = {}
      }
    },
    "aws-lambda-with-spring-product" = {
      memory_size = 3008
      environment_variables = {
        API_BASE_URI = "/product"
      }
      enable_function_url = false
      api_gateway_route = {
        path_prefix   = "product"
        path_rewrites = {
          "product" = "/product"
        }
      }
    },
    "aws-lambda-with-spring-planning" = {
      memory_size = 3008
      environment_variables = {
        API_BASE_URI = "/planning"
      }
      enable_function_url = false
      api_gateway_route = {
        path_prefix   = "nothing"
        path_rewrites = {
          "nothing" = "/planning"
        }
      }
    }
  }

  domain = {
    name = "api.your-task.dev"
  }

  ecr_repos  = local.ecr
  s3_buckets = toset(local.s3)

  http_api_gateway_routes = { for k, v in local.functions : k => v if v.api_gateway_route != null }
}

module "ecr" {
  source           = "./modules/ecr"
  for_each         = local.ecr_repos
  name             = each.key
  aws_region       = "eu-north-1"
  source_image     = each.value.source_image
  source_image_tag = each.value.source_image_tag
}

module "s3" {
  source      = "./modules/s3"
  for_each    = local.s3_buckets
  bucket_name = each.key
}

module "lambda" {
  source   = "./modules/lambda"
  for_each = local.functions

  name                  = each.key
  image_uri             = "${module.ecr["aws-lambda-with-spring"].repository_url}:latest"
  memory_size           = each.value.memory_size
  environment_variables = each.value.environment_variables
  enable_function_url   = each.value.enable_function_url

  depends_on = [module.ecr]
}

# Step 1: create the ACM certificate (DNS validation method)
module "acm" {
  source      = "./modules/acm"
  count       = local.domain.name != "" ? 1 : 0
  domain_name = local.domain.name
}

# Step 2: create a Route53 hosted zone for the subdomain api.your-task.dev
resource "aws_route53_zone" "api" {
  count = local.domain.name != "" ? 1 : 0
  name  = local.domain.name
}

# Step 3: write the ACM validation CNAME records into Route53
resource "aws_route53_record" "acm_validation" {
  for_each = local.domain.name != "" ? {
    for dvo in module.acm[0].validation_options : dvo.domain_name => dvo
  } : {}

  zone_id = aws_route53_zone.api[0].zone_id
  name    = each.value.resource_record_name
  type    = each.value.resource_record_type
  ttl     = 300
  records = [each.value.resource_record_value]
}

# Step 4: wait for ACM to confirm the certificate is validated
resource "aws_acm_certificate_validation" "this" {
  count                   = local.domain.name != "" ? 1 : 0
  certificate_arn         = module.acm[0].certificate_arn
  validation_record_fqdns = [for dvo in module.acm[0].validation_options : dvo.resource_record_name]

  depends_on = [aws_route53_record.acm_validation]
}

# Step 5: create API Gateway with the validated certificate
module "api_gateway_route" {
  source = "./modules/api-gateway"
  count  = length(local.http_api_gateway_routes) > 0 ? 1 : 0
  name   = "aws-lambda-api"

  domain_name     = local.domain.name != "" ? local.domain.name : null
  certificate_arn = local.domain.name != "" ? aws_acm_certificate_validation.this[0].certificate_arn : null

  integrations = {
    for k, v in local.http_api_gateway_routes :
    "ANY /${v.api_gateway_route.path_prefix}/{proxy+}" => {
      lambda_function_arn  = module.lambda[k].function_arn
      lambda_function_name = module.lambda[k].function_name
      path_rewrites        = v.api_gateway_route.path_rewrites
    }
  }
}

# Step 6: point api.your-task.dev → API Gateway custom domain via Route53 ALIAS record
resource "aws_route53_record" "api" {
  count   = local.domain.name != "" ? 1 : 0
  zone_id = aws_route53_zone.api[0].zone_id
  name    = local.domain.name
  type    = "A"

  alias {
    name                   = module.api_gateway_route[0].custom_domain_target
    zone_id                = module.api_gateway_route[0].custom_domain_hosted_zone_id
    evaluate_target_health = true
  }
}
